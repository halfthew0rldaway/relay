{
    "name": "relay-web",
    "version": "1.0.1",
    "description": "Zero-copy, local-first file transfer over LAN.",
    "author": "bleu <bleu@localhost>",
    "homepage": "https://github.com/bleu/locallink",
    "main": "desktop.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "desktop": "electron desktop.js",
        "build:linux": "electron-builder --linux"
    },
    "dependencies": {
        "bonjour-service": "^1.2.1",
        "express": "^4.19.2",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "electron": "^41.1.0",
        "electron-builder": "^26.8.1"
    },
    "build": {
        "appId": "com.bleu.relay",
        "productName": "Relay",
        "linux": {
            "maintainer": "bleu <bleu@localhost>",
            "category": "Network",
            "target": [
                "rpm",
                "AppImage"
            ]
        },
        "asar": false,
        "files": [
            "public/**/*",
            "server/**/*",
            "server.js",
            "desktop.js",
            "package.json"
        ]
    }
}